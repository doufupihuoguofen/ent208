# Resonance 全栈环境变量
# 复制此文件为 .env 并填写真实值

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-refresh-in-production-use-a-long-random-string

# ── Pinecone (可选，留空则跳过向量写入) ──────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=resonance-audio

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Steam OAuth (可选) ────────────────────────────────────────────────────────
STEAM_API_KEY=

# ── AWS S3 (可选，留空则使用本地存储) ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=resonance-audio
