# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://resonance:resonance_pass@localhost:5432/resonance_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# AWS S3 (optional – leave blank to use local storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=resonance-audio

# Audio Service (Python microservice)
AUDIO_SERVICE_URL="http://localhost:8000"

# OAuth (Steam)
STEAM_API_KEY=

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
